{
  "name": "@cordisjs/plugin-cli-cordis",
  "version": "1.0.2",
  "description": "CLI for Cordis Framework",
  "main": "lib/index.js",
  "typings": "lib/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./worker": {
      "types": "./lib/worker/index.d.ts",
      "default": "./lib/worker/index.js"
    },
    "./main": "./lib/worker/main.js",
    "./src/*": "./src/*",
    "./package.json": "./package.json"
  },
  "files": [
    "lib",
    "src"
  ],
  "peerDependencies": {
    "@cordisjs/plugin-cli": "^1.1.0",
    "@cordisjs/plugin-loader": "^1.0.0-rc.0",
    "@cordisjs/plugin-logger": "^1.0.1",
    "cordis": "^4.0.0-rc.0"
  },
  "devDependencies": {
    "@cordisjs/plugin-cli": "^1.1.0",
    "@cordisjs/plugin-loader": "^1.0.0-rc.0",
    "@cordisjs/plugin-logger": "^1.0.1",
    "cordis": "^4.0.0-rc.0"
  },
  "dependencies": {
    "cosmokit": "^1.8.1",
    "kleur": "^4.1.5"
  }
}

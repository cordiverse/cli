{
  "name": "@root/cli",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "packageManager": "yarn@4.13.0",
  "workspaces": [
    "external/*",
    "packages/*"
  ],
  "license": "MIT",
  "scripts": {
    "yakumo": "yakumo --import tsx --import yml-register",
    "build": "yarn yakumo esbuild && yarn yakumo tsc",
    "lint": "eslint --cache",
    "test": "yarn yakumo mocha --import tsx",
    "test:text": "shx rm -rf coverage && c8 -r text yarn test",
    "test:json": "shx rm -rf coverage && c8 -r json yarn test",
    "test:html": "shx rm -rf coverage && c8 -r html yarn test"
  },
  "devDependencies": {
    "@cordisjs/eslint-config": "^1.1.1",
    "@cordisjs/plugin-include": "^1.0.1",
    "@cordisjs/plugin-loader": "^1.0.0-rc.0",
    "@sinonjs/fake-timers": "^6.0.1",
    "@types/node": "^25.5.0",
    "@types/sinonjs__fake-timers": "^6.0.4",
    "c8": "^10.1.3",
    "cordis": "^4.0.0-rc.0",
    "esbuild": "^0.27.4",
    "eslint": "^8.57.0",
    "mocha": "^11.7.5",
    "shx": "^0.4.0",
    "tsx": "npm:@cordiverse/tsx@4.19.3-fix.3",
    "typescript": "^5.8.2",
    "yakumo": "^3.0.3",
    "yakumo-esbuild": "^3.0.1",
    "yakumo-mocha": "^3.0.1",
    "yakumo-tsc": "^3.0.1",
    "yml-register": "^1.2.5"
  }
}
